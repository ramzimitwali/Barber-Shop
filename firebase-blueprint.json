{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "Grooming service offered by the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string", "enum": ["hair", "beard", "combo", "vip"] },
        "popular": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "duration", "category"]
    },
    "Barber": {
      "title": "Barber",
      "description": "Master barber profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "instagram": { "type": "string" },
        "rating": { "type": "number" },
        "yearsExperience": { "type": "number" }
      },
      "required": ["id", "name", "role", "image"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled grooming session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "userPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "barberId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalPrice": { "type": "number" }
      },
      "required": ["userId", "serviceId", "barberId", "date", "time", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Client feedback and rating",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Membership": {
      "title": "Membership",
      "description": "Grooming lounge membership record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled", "expired"] },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" }
      },
      "required": ["userId", "planId", "status"]
    }
  },
  "firestore": {
    "services": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "List of grooming services"
    },
    "barbers": {
      "schema": { "$ref": "#/entities/Barber" },
      "description": "List of master barbers"
    },
    "appointments": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Customer appointments"
    },
    "reviews": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Public client reviews"
    },
    "memberships": {
      "schema": { "$ref": "#/entities/Membership" },
      "description": "User membership subscriptions"
    }
  }
}
